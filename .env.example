# Copy to `.env` for local tools that read env files (optional).
# Streamlit Cloud: set variables in the app’s **Settings → Environment variables**.

# Absolute path to the Hugging Face classifier folder (must contain config.json).
# Inside Docker Compose Streamlit service this is set to /models/classifier automatically.
FEEDBACK_MODEL_DIR=

# Reflex: public URL of the backend (WebSocket + API), e.g. https://your-host:8000
API_URL=
